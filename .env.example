# Copy this file to .env and fill in your values.
# Do NOT commit your real .env file.

###############################################################################
# Core LLM configuration (used by example notebooks via python-dotenv)
###############################################################################

# If using Azure OpenAI with LangChain AzureChatOpenAI
# Your Azure resource endpoint (no trailing path). Example:
# "https://<your-azure-openai-resource>.openai.azure.com"
API_BASE=

# Always set API_TYPE="azure" when using Azure OpenAI with LangChain AzureChatOpenAI
API_TYPE=

# Azure OpenAI API version (must be supported by your resource)
# Example: "2024-02-15-preview"
API_VERSION=

# The name of your deployed model in Azure OpenAI (Deployment Name)
DEPLOYMENT_NAME=

# API key for your Azure OpenAI resource
API_KEY=

# Optional: Model version string used in examples or docs (informational)
# Example: "gpt-4-turbo-2024-04-09"
MODEL_VERSION=

###############################################################################
# Optional providers (only if you use those sections in the notebooks)
###############################################################################

# Mistral API key (uncomment and/or set if you run the Mistral example cells)
# Some notebooks show setting MISTRAL_API_KEY from this value
M_KEY=

# Hugging Face cache directory (optional). Uncomment to override defaults.
# HF_HOME=
# TRANSFORMERS_CACHE=

###############################################################################
# Notes
# - Place the .env file at the repository root.
# - The example notebooks load it with load_dotenv(find_dotenv()).
# - Keep your secrets out of version control.
###############################################################################
